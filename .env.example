# ── Discord ───────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Set to your test server ID for instant slash command registration during dev.
# Leave blank (or remove) for global registration in production.
DISCORD_GUILD_ID=

# ── Server ────────────────────────────────────────────────────────────────────
# Port for the status dashboard / health endpoint
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (relative to project root)
DATABASE_PATH=sigmoji.db
